# Hugging Face API token (free at https://huggingface.co/settings/tokens)
# When creating the token, enable "Make calls to Inference Providers"
HF_API_TOKEN=hf_your_token_here

# MongoDB for accounts, history, and settings
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/ai-or-not

# Optional: override session signing secret
# SESSION_SECRET=replace-with-a-long-random-string

# Alias also supported:
# HF_TOKEN=hf_your_token_here

# Optional: override detection model (single model; ensemble still runs defaults too)
# HF_DETECTION_MODEL=Ateeqq/ai-vs-human-image-detector

# Optional: AI threshold 0–1 (default 0.58). Higher = fewer false "AI" labels.
# AI_DETECTION_THRESHOLD=0.58

# Local dev only: Python fallback API URL
# LOCAL_PREDICT_URL=http://127.0.0.1:5328/api/predict

# Vercel production: add HF_API_TOKEN in Project Settings → Environment Variables
