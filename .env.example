# Hugging Face API token (free at https://huggingface.co/settings/tokens)
# When creating the token, enable "Make calls to Inference Providers"
HF_API_TOKEN=hf_your_token_here

# Alias also supported:
# HF_TOKEN=hf_your_token_here

# Optional: override detection model
# HF_DETECTION_MODEL=boluobobo/ItsNotAI-ai-detector-v2

# Local dev only: Python fallback API URL
# LOCAL_PREDICT_URL=http://127.0.0.1:5328/api/predict
